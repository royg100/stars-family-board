# העתק ל־.env ליד stars.db והרץ את השרת מ־backend/

# כשהפרונט ב־https://stars-family-board.netlify.app (או פרוקסי Netlify) — אפשר ריק אם אין קריאות ישירות מהדפדפן ל־API.
# אם הדפדפן קורא ישירות לשרת Python (בלי פרוקסי Netlify), חובה להגדיר:
STARS_CORS_ALLOW_ORIGINS=https://stars-family-board.netlify.app

# בפרודקשן עם HTTPS (Railway, Render וכו׳) — עוגיות התחברות:
STARS_COOKIE_SECURE=true
